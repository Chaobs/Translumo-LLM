    <system:String x:Key="Str.LlmSettings.Testing">テスト中…</system:String>
    <system:String x:Key="Str.LlmSettings.TestSuccess">接続に成功しました！</system:String>
    <system:String x:Key="Str.LlmSettings.TestFail">接続に失敗しました: {0}</system:String>
