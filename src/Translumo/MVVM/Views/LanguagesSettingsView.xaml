<UserControl
    x:Class="Translumo.MVVM.Views.LanguagesSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:System="clr-namespace:System;assembly=mscorlib"
    xmlns:controls="clr-namespace:Translumo.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:translation="clr-namespace:Translumo.Translation;assembly=Translumo.Translation"
    xmlns:llm="clr-namespace:Translumo.Translation.Llm;assembly=Translumo.Translation"
    xmlns:tts="clr-namespace:Translumo.TTS;assembly=Translumo.TTS"
    xmlns:common="clr-namespace:Translumo.MVVM.Common"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ObjectDataProvider
            x:Key="dataFromEnum"
            MethodName="GetValues"
            ObjectType="{x:Type System:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="translation:Translators" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider
            x:Key="llmProviders"
            MethodName="GetValues"
            ObjectType="{x:Type System:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="llm:LlmProvider" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider
            x:Key="ttsSystems"
            MethodName="GetValues"
            ObjectType="{x:Type System:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="tts:TTSEngines" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <common:TranslatorNameConverter x:Key="TranslatorNameConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="475" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <StackPanel.Resources>
                <Style TargetType="{x:Type StackPanel}">
                    <Setter Property="Margin" Value="0,0,0,20" />
                </Style>
            </StackPanel.Resources>
            <StackPanel Orientation="Horizontal">
                <ComboBox
                    DisplayMemberPath="DisplayName"
                    FontSize="14"
                    ItemsSource="{Binding Path=AvailableLanguages}"
                    SelectedValue="{Binding Path=TranslateFromLang}"
                    SelectedValuePath="LanguageDescriptor.Language"
                    Style="{StaticResource ComboBoxBase}" />
                <Label
                    Margin="10,0,0,0"
                    Content="{DynamicResource Str.LangSettings.SourceLang}"
                    Style="{StaticResource ControlCaptionLabel}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <ComboBox
                    DisplayMemberPath="DisplayName"
                    FontSize="14"
                    ItemsSource="{Binding Path=AvailableTranslationLanguages}"
                    MaxDropDownHeight="300"
                    SelectedValue="{Binding Path=TranslateToLang}"
                    SelectedValuePath="LanguageDescriptor.Language"
                    Style="{StaticResource ComboBoxBase}" />
                <Label
                    Margin="10,0,0,0"
                    HorizontalAlignment="Stretch"
                    Content="{DynamicResource Str.LangSettings.TranslationLang}"
                    Style="{StaticResource ControlCaptionLabel}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <ComboBox
                    Width="130"
                    FontSize="14"
                    ItemsSource="{Binding Source={StaticResource dataFromEnum}}"
                    SelectedItem="{Binding Path=Model.Translator}"
                    Style="{DynamicResource MaterialDesignComboBox}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource TranslatorNameConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Label
                    Margin="10,0,0,0"
                    HorizontalAlignment="Stretch"
                    Content="{DynamicResource Str.LangSettings.Translator}"
                    Style="{StaticResource ControlCaptionLabel}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <ComboBox
                    Width="130"
                    FontSize="14"
                    ItemsSource="{Binding Source={StaticResource ttsSystems}}"
                    SelectedItem="{Binding Path=TtsSystem}"
                    Style="{DynamicResource MaterialDesignComboBox}" />
                <Label
                    Margin="10,0,0,0"
                    HorizontalAlignment="Stretch"
                    Content="{DynamicResource Str.LangSettings.TtsSystem}"
                    Style="{StaticResource ControlCaptionLabel}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Visibility="{Binding IsTtsWindowsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ComboBox 
                    ItemsSource="{Binding AvailableVoices}"
                    SelectedItem="{Binding SelectedVoice, Mode=TwoWay}"
                    DisplayMemberPath="Name"
                    Width="130"
                    FontSize="14"
                    Style="{DynamicResource MaterialDesignComboBox}"/>
                <Label
                    Margin="10,0,0,0"
                    HorizontalAlignment="Stretch"
                    Content="Voices"
                    Style="{StaticResource ControlCaptionLabel}" />
            </StackPanel>

            <GroupBox Margin="0,20,0,0" Style="{StaticResource MaterialDesignGroupBox}">
                <GroupBox.Header>
                    <Label
                        Margin="0,-7,0,-7"
                        Content="{DynamicResource Str.ProxySettings.Proxy}"
                        Style="{StaticResource SecondaryHeaderLabel}" />
                </GroupBox.Header>
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        Style="{StaticResource TextBlockBase}"
                        Text="{DynamicResource Str.ProxySettings.Note}"
                        TextWrapping="WrapWithOverflow" />
                    <Button
                        Margin="0,5,0,0"
                        HorizontalAlignment="Left"
                        Command="{Binding ProxySettingsClickedCommand}"
                        Content="{DynamicResource Str.Button.SettingProxy}"
                        Style="{StaticResource PrimaryButton}" />
                </StackPanel>
            </GroupBox>

            <GroupBox
                Margin="0,20,0,0"
                Style="{StaticResource MaterialDesignGroupBox}"
                Visibility="{Binding IsLlmSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <GroupBox.Header>
                    <Label
                        Margin="0,-7,0,-7"
                        Content="{DynamicResource Str.LlmSettings.Header}"
                        Style="{StaticResource SecondaryHeaderLabel}" />
                </GroupBox.Header>
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="12"
                        Style="{StaticResource TextBlockBase}"
                        Text="{DynamicResource Str.LlmSettings.Note}"
                        TextWrapping="WrapWithOverflow" />
                    <StackPanel
                        Margin="0,0,0,10"
                        Orientation="Horizontal">
                        <ComboBox
                            Width="200"
                            HorizontalAlignment="Left"
                            FontSize="13"
                            ItemsSource="{Binding LlmProfileNames}"
                            SelectedItem="{Binding SelectedLlmProfileName}"
                            Style="{DynamicResource MaterialDesignComboBox}" />
                        <Button
                            Margin="8,0,0,0"
                            Command="{Binding AddLlmProfileCommand}"
                            Content="{DynamicResource Str.LlmSettings.AddProfile}"
                            Style="{StaticResource PrimaryButton}" />
                        <Button
                            Margin="8,0,0,0"
                            Command="{Binding DeleteLlmProfileCommand}"
                            Content="{DynamicResource Str.LlmSettings.DeleteProfile}"
                            Style="{StaticResource PrimaryButton}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <Label
                            Margin="0,0,0,2"
                            Content="{DynamicResource Str.LlmSettings.Provider}"
                            Style="{StaticResource ControlCaptionLabel}" />
                        <ComboBox
                            Width="200"
                            HorizontalAlignment="Left"
                            FontSize="14"
                            ItemsSource="{Binding Source={StaticResource llmProviders}}"
                            SelectedItem="{Binding Path=LlmSettings.Provider}"
                            Style="{DynamicResource MaterialDesignComboBox}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <Label
                            Margin="0,0,0,2"
                            Content="{DynamicResource Str.LlmSettings.ApiKey}"
                            Style="{StaticResource ControlCaptionLabel}" />
                        <TextBox
                            Width="430"
                            HorizontalAlignment="Left"
                            FontSize="13"
                            Style="{StaticResource TextBoxBase}"
                            Text="{Binding Path=LlmSettings.ApiKey, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <Label
                            Margin="0,0,0,2"
                            Content="{DynamicResource Str.LlmSettings.Endpoint}"
                            Style="{StaticResource ControlCaptionLabel}" />
                        <TextBox
                            Width="430"
                            HorizontalAlignment="Left"
                            FontSize="13"
                            Style="{StaticResource TextBoxBase}"
                            Text="{Binding Path=LlmSettings.Endpoint, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <Label
                            Margin="0,0,0,2"
                            Content="{DynamicResource Str.LlmSettings.Model}"
                            Style="{StaticResource ControlCaptionLabel}" />
                        <TextBox
                            Width="430"
                            HorizontalAlignment="Left"
                            FontSize="13"
                            Style="{StaticResource TextBoxBase}"
                            Text="{Binding Path=LlmSettings.ModelName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <Label
                            Margin="0,0,0,2"
                            Content="{DynamicResource Str.LlmSettings.SystemPrompt}"
                            Style="{StaticResource ControlCaptionLabel}" />
                        <TextBox
                            Width="430"
                            Height="120"
                            HorizontalAlignment="Left"
                            VerticalScrollBarVisibility="Auto"
                            AcceptsReturn="True"
                            FontSize="12"
                            Style="{StaticResource TextBoxBase}"
                            Text="{Binding Path=LlmSettings.SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                        <StackPanel Width="215">
                            <Label
                                Margin="0,0,0,2"
                                Content="{DynamicResource Str.LlmSettings.Temperature}"
                                Style="{StaticResource ControlCaptionLabel}" />
                            <StackPanel Orientation="Horizontal">
                                <Slider
                                    Width="150"
                                    Maximum="1"
                                    Minimum="0"
                                    SmallChange="0.05"
                                    TickFrequency="0.05"
                                    Value="{Binding Path=LlmSettings.Temperature}" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Style="{StaticResource TextBlockBase}"
                                    Text="{Binding Path=LlmSettings.Temperature, StringFormat=F2}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Width="215">
                            <Label
                                Margin="0,0,0,2"
                                Content="{DynamicResource Str.LlmSettings.MaxTokens}"
                                Style="{StaticResource ControlCaptionLabel}" />
                            <TextBox
                                Width="120"
                                HorizontalAlignment="Left"
                                FontSize="13"
                                Style="{StaticResource TextBoxBase}"
                                Text="{Binding Path=LlmSettings.MaxTokens, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button
                            Margin="0,4,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding TestLlmConnectionCommand}"
                            Content="{DynamicResource Str.LlmSettings.Test}"
                            Style="{StaticResource PrimaryButton}" />
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="Green"
                            Style="{StaticResource TextBlockBase}"
                            Text="{Binding LlmTestStatus}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>
        <DockPanel
            Grid.Row="0"
            Grid.Column="1"
            Margin="9,0,0,0"
            Visibility="{Binding ProxySettingsIsOpened, Converter={StaticResource BooleanToVisibilityConverter}}">
            <controls:ProxyEditList
                x:Name="ProxyListControl"
                Padding="9,0,0,0"
                HorizontalAlignment="Stretch"
                AddCommand="{Binding ProxyItemAddCommand}"
                BorderBrush="{StaticResource PrimaryHueMidBrush}"
                BorderThickness="1,0,0,0"
                DeleteCommand="{Binding ProxyItemDeletedCommand}"
                SourceList="{Binding Path=ProxyCollection, Mode=TwoWay}"
                SubmitCommand="{Binding ProxySettingsSubmitCommand}"
                UseLayoutRounding="False" />
        </DockPanel>
    </Grid>
</UserControl>
